# Copy to .env and fill in real values. Never commit .env.
#
#   cp .env.example .env
#   ${EDITOR:-nano} .env

# ---- required: iKuai read-only API ----
# Base URL of the iKuai web UI / API (no trailing slash required)
IKUAI_URL=http://router.lan
IKUAI_USERNAME=api
IKUAI_PASSWORD=change-me

# ---- optional: exporter modules / TLS ----
IKUAI_MODULES=sysStat,lanDevice,interfaceInfo
IKUAI_INSECURE_SKIP=true
IKUAI_LEVEL=info

# ---- optional: host port mappings ----
# Dashboard (default 3000)
IKUAIVIEW_PORT=3000
# Exporter metrics (default 9191 -> container 9090)
IKUAI_EXPORTER_PORT=9191
# Prometheus UI (default 9090)
PROMETHEUS_PORT=9090

# ---- optional: in-network service URLs (defaults are correct for compose) ----
IKUAI_EXPORTER_URL=http://ikuai-exporter:9090
PROMETHEUS_URL=http://prometheus:9090

# Prometheus TSDB retention
PROMETHEUS_RETENTION=30d
