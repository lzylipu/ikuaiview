# 复制为 .env 后填写真实值。切勿提交 .env 到 Git。
#
#   cp .env.example .env
#   nano .env

# ---- 必填：iKuai 只读 API ----
IKUAI_URL=http://192.168.1.1
IKUAI_USERNAME=api
IKUAI_PASSWORD=change-me

# ---- 可选：看板镜像 ----
# Docker Hub（默认）
IKUAIVIEW_IMAGE=lzylipu/ikuaiview:latest
# 或 GHCR：
# IKUAIVIEW_IMAGE=ghcr.io/lzylipu/ikuaiview:latest

# ---- 可选：轮询降频（一般不用改，默认已合理）----
# IKUAIVIEW_WS_PUSH_SECONDS=5
# IKUAIVIEW_EXPORTER_CACHE_TTL=5
# IKUAIVIEW_METADATA_POLL_SECONDS=30
# IKUAIVIEW_HOMEPAGE_TTL=300
